rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function ownsDocument() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function ownsIncomingDocument() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    function publicOrOwner() {
      return resource.data.visibility == 'public' || ownsDocument();
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'userId',
          'email',
          'username',
          'usernameLower',
          'displayName',
          'photoURL',
          'favoriteFranchise',
          'favoritePlayer',
          'updatedAt'
        ]);
      allow update: if isOwner(userId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'userId',
          'email',
          'username',
          'usernameLower',
          'displayName',
          'photoURL',
          'favoriteFranchise',
          'favoritePlayer',
          'updatedAt'
        ]);
    }

    match /publicProfiles/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'userId',
          'username',
          'displayName',
          'photoURL',
          'favoriteFranchise',
          'favoritePlayer',
          'updatedAt'
        ]);
      allow delete: if isOwner(userId);
    }

    match /usernames/{username} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasOnly(['userId', 'username', 'updatedAt'])
        && !exists(/databases/$(database)/documents/usernames/$(username));
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasOnly(['userId', 'username', 'updatedAt']);
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /auctionResults/{id} {
      allow read: if publicOrOwner();
      allow create: if ownsIncomingDocument();
      allow update, delete: if ownsDocument();
    }

    match /dreamTeams/{id} {
      allow read: if publicOrOwner();
      allow create: if ownsIncomingDocument();
      allow update, delete: if ownsDocument();
    }

    match /quizResults/{id} {
      allow read: if publicOrOwner();
      allow create: if ownsIncomingDocument();
      allow update, delete: if ownsDocument();
    }

    match /fanPosts/{id} {
      allow read: if publicOrOwner();
      allow create: if ownsIncomingDocument();
      allow update: if ownsDocument()
        || (
          signedIn()
          && resource.data.visibility == 'public'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'replies', 'updatedAt'])
        );
      allow delete: if ownsDocument();
    }

    match /favorites/{id} {
      allow read: if ownsDocument();
      allow create: if ownsIncomingDocument();
      allow update, delete: if ownsDocument();
    }

    match /follows/{id} {
      allow read: if signedIn() && resource.data.followerId == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.followerId == request.auth.uid
        && request.resource.data.followingId != request.auth.uid
        && request.resource.data.keys().hasOnly([
          'followerId',
          'followingId',
          'followingName',
          'followingAvatar',
          'createdAt'
        ]);
      allow delete: if signedIn() && resource.data.followerId == request.auth.uid;
    }

    match /directMessages/{id} {
      allow read: if signedIn()
        && (resource.data.senderId == request.auth.uid || resource.data.receiverId == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.receiverId != request.auth.uid
        && request.resource.data.keys().hasOnly([
          'senderId',
          'senderName',
          'receiverId',
          'receiverName',
          'body',
          'createdAt'
        ]);
    }
  }
}
